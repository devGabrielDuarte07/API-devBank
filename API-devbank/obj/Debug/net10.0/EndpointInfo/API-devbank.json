  "components": {
    "schemas": {
      "CriarUsuarioRequest": {
        "required": [
          "cpf",
          "email",
          "nome",
          "senha",
          "telefone"
        ],
        "type": "object",
        "properties": {
          "nome": {
            "maxLength": 100,
            "minLength": 3,
            "type": "string"
          },
          "cpf": {
            "maxLength": 11,
            "minLength": 11,
            "type": "string"
          },
          "email": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "telefone": {
            "maxLength": 20,
            "minLength": 1,
            "type": "string"
          },
          "senha": {
            "minLength": 8,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "required": [
          "senha"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "nullable": true
          },
          "senha": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "TransferenciaRequest": {
        "type": "object",
        "properties": {
          "contaDestinoId": {
            "type": "integer",
            "format": "int32"
          },
          "valor": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "ValorRequest": {
        "type": "object",
        "properties": {
          "valor": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
